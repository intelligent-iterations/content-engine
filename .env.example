# xAI API key (optional — can use browser cookie auth instead)
# XAI_API_KEY=your_xai_key_here
# XAI_SPEND_BUDGET_USD=25
# XAI_SPEND_CAP_USD=40
# XAI_SPEND_SCOPE=monthly

# Whisper model for auto-captions (optional, default: base.en)
# WHISPER_MODEL=base.en

# Grok browser automation overrides (optional)
# GROK_WEB_COOKIES_PATH=
# GROK_WEB_STATE_PATH=
# GROK_WEB_USER_DATA_DIR=
# GROK_WEB_TIMEOUT_MS=240000
# GROK_WEB_HEADED=0
# GROK_WEB_DEBUG=0
# GROK_IMAGE_OUT_DIR=

# Shared output root (default: ~/ii/content-engine/)
# All repos in the ii ecosystem read/write content here.
# II_ROOT=~/ii/content-engine

# Post outro clip path (default: II_ROOT/assets/plug.mov)
# CONTENT_ENGINE_POST_OUTRO_PATH=

# Python binary override (optional, default: python3)
# CONTENT_GEN_PYTHON=python3

# Instagram credentials (optional — prefer browser cookie auth instead)
# INSTAGRAM_USERNAME=
# INSTAGRAM_PASSWORD=

# TikTok account name (optional)
# TIKTOK_ACCOUNT_NAME=
